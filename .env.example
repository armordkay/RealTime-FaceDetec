APP_NAME=Face Attendance API
APP_ENV=dev
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-this-before-deploy-with-at-least-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATA_BACKEND=sqlite
DATABASE_URL=sqlite:///./face_attendance.db
SUPABASE_URL=
SUPABASE_KEY=

# For Supabase Postgres, set:
# DATA_BACKEND=postgres
# DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:YOUR-PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require&connect_timeout=10

RECOGNITION_THRESHOLD=0.65
# Chống ảnh giả (anti-spoofing). LIVENESS_ENABLED=false để tắt nhanh khi demo bị nhận nhầm mặt thật.
# LIVENESS_MIN_SCORE: ngưỡng tin cậy tối thiểu coi là mặt thật (0..1), hạ xuống nếu hay bị từ chối oan.
LIVENESS_ENABLED=true
LIVENESS_MIN_SCORE=0.5
ANOMALY_SAFE_SCORE_THRESHOLD=0.80
ANOMALY_SHORT_SESSION_MINUTES=15
ANOMALY_NEAR_EVENT_MINUTES=5
KIOSK_API_KEY=

MEDIA_DIR=media
PUBLIC_MEDIA_URL=/media
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=face-attendance
MINIO_SECURE=false
MINIO_PUBLIC_URL=

ALERT_EMAIL_ENABLED=false
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_FROM=
ALERT_EMAIL_RECIPIENTS=
ALERT_SMTP_USE_TLS=true

ATTENDANCE_EMAIL_ENABLED=true
ATTENDANCE_EMAIL_AFTER_SHIFT_MINUTES=30
ATTENDANCE_EMAIL_SCAN_INTERVAL_SECONDS=60
