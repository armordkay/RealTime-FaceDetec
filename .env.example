APP_NAME=Face Attendance API
APP_ENV=dev
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change-this-before-deploy-with-at-least-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATA_BACKEND=sqlite
DATABASE_URL=sqlite:///./face_attendance.db
SUPABASE_URL=
SUPABASE_KEY=

# For Supabase Postgres, set:
# DATA_BACKEND=postgres
# DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:YOUR-PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require&connect_timeout=10

RECOGNITION_THRESHOLD=0.65
KIOSK_API_KEY=

MEDIA_DIR=media
PUBLIC_MEDIA_URL=/media
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=face-attendance
MINIO_SECURE=false
MINIO_PUBLIC_URL=
